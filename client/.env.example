# ─────────────────────────────────────────────
#  PWI client (Vite) — environment variables
#  Copy to `.env` and adjust as needed.
# ─────────────────────────────────────────────

# API base URL.
# Development: keep as /api (proxied to the server by Vite).
# Production: set to your deployed API URL, e.g. https://your-api.onrender.com/api
VITE_API_URL=/api
